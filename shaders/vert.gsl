push {
  uvec2 _ScreenDims;
};

out vec2 _UV;

void main() {
  const vec2 uvMap[6] = vec2[](
    vec2(-1.0f, -1.0f),
    vec2(-1.0f, 1.0f),
    vec2(1.0f, 1.0f),
    vec2(1.0f, 1.0f),
    vec2(1.0f, -1.0f),
    vec2(-1.0f, -1.0f)
  );

  vec2 uv = uvMap[gl_VertexIndex];

  gl_Position = vec4(uv, 0.0, 1.0);
  _UV = uv;
}
